{
  // System
  "custom/system": {
    "format": "Ņæ│ {}",
    "return-type": "string",
    "tooltip-format": "DotFiles version",
    "exec": "sleep 0.1 && cat ~/hyprdots/dotfiles/version",
    "interval" : "once"
  },

  // System group
  "group/system": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 450,
      "children-class": "not-memory",
      "transition-left-to-right": false,
      "click-to-reveal": true
    },
    "modules": [
      "custom/system",
      "group/cpu_info",
      "memory",
      "group/gpu_info",

      "power-profiles-daemon",
      "disk",
      "custom/pacman"
    ]
  },

  // CPU group
  "group/cpu_info": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 450,
      "children-class": "not-memory",
      "transition-left-to-right": false
    },
    "modules": [
      "cpu",
      "temperature"
    ]
  },

  // Cpu usage
  "cpu": {
    "interval": 15,
    "format": "{icon}",
    "rotate": 270,
    "format-icons": ["¾░Ø”","¾░¬×","¾░¬¤","¾░¬Ā","¾░¬Ī","¾░¬ó","¾░¬Ż","¾░¬ż","¾░¬ź"],
    "tooltip-format": "12213"
  },

  "load": {
    "interval": 10,
    "format": "load: {load1}",
    "max-length": 10
  },

  // Cpu temp
  "temperature": {
    "interval": 25,
    "thermal-zone": 2,
    "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
    "critical-threshold": 75,

    "format": "{temperatureC}┬░C {icon}",
    "format-critical": "<span foreground='red'>{temperatureC}┬░C {icon}</span>",
    "tooltip-format": "CPU Hotspot {temperatureC}┬░C{icon}",

    "format-icons": [
      "’ŗŗ", // Icon: temperature-empty
      "’ŗŖ", // Icon: temperature-quarter
      "’ŗē", // Icon: temperature-half
      "’ŗł", // Icon: temperature-three-quarters
      "’ŗł"  // Icon: temperature-full
    ]
  },


  // GPU group
  "group/gpu_info": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 450,
      "children-class": "not-memory",
      "transition-left-to-right": false
    },
    "modules": [
      "custom/gpu",
      "temperature#4"
    ]
  },

  // GPU
  "custom/gpu": {
    "signal": 8,
    "format": "¾░Š▓ {}",
    "return-type": "json",
    "restart-interval": "once",
    "exec": "sleep 0.1 && bash ~/.config/waybar/scripts/utils/gpu.sh"
  },

  // GPU temp
  "temperature#4": {
    "interval": 25,
    "thermal-zone": 4,
    "hwmon-path": "/sys/class/hwmon/hwmon4/temp1_input",
    "critical-threshold": 75,

    "format": "{temperatureC}┬░C {icon}",
    "format-critical": "<span foreground='red'>{temperatureC}┬░C {icon}</span>",
    "tooltip-format": "CPU Hotspot {temperatureC}┬░C{icon}",

    "format-icons": [
      "’ŗŗ", // Icon: temperature-empty
      "’ŗŖ", // Icon: temperature-quarter
      "’ŗē", // Icon: temperature-half
      "’ŗł", // Icon: temperature-three-quarters
      "’ŗł"  // Icon: temperature-full
    ]
  },


  // Power menu
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "’ēĆ Power profile\n - ’Ćō\tDriver: \t{driver}\n - {icon}\tProfile: \t{profile}",
    "tooltip": true,
    "format-icons": {
      "default": "’ā¦",
      "performance": "’ā¦",
      "balanced": "’ēÄ",
      "power-saver": "’ü¼"
    }
  },

  // Disk / use
  "disk": {
    "interval": 90,
    "format": "’éĀ {percentage_used}%",
    "path": "/"
  },

  // Updates Count | Total packages
  "custom/pacman": {
    "signal": 8,
    "format": "{}",
    "return-type": "json",
    "restart-interval": 600,
    "exec-on-event": true,
    "exec": "bash ~/.config/waybar/scripts/utils/pacman.sh check",

    "on-click": "bash ~/.config/waybar/scripts/dialog.sh float-small update",
    "on-click-right": "bash ~/.config/waybar/scripts/dialog.sh float-small unused"
  },

  // Memory usage
  "memory": {
    "rotate": 270,
    "format": "{icon}",
    "format-icons": ["¾░Ø”","¾░¬×","¾░¬¤","¾░¬Ā","¾░¬Ī","¾░¬ó","¾░¬Ż","¾░¬ż","¾░¬ź"],
    "max-length": 10,
    "tooltip-format": "’āē Memory\n - Ņ┐ģ {used:0.1f}/{total:0.1f} GB \t{avail:0.1f} GB - {percentage}%\n - ¾░ōĪ {swapUsed:0.1f}/{swapTotal:0.1f} GB\t{swapAvail:0.1f} GB - {swapPercentage}%"
  }
}